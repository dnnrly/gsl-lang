@startuml

participant Client
participant Server
participant Database

Client -> Server: Request
Server --> Client: Response
Server ->> Database: Query
Database -->> Server: Result
Client -> Server ++: Login
    Server -> Database: Lookup
    Database --> Server: User data
    Server --> Client: Token
return

Client ->> Server ++: Async call
    Server ->> Database: Async query
    Database -->> Server: Stream
    Server --> Client: Done
return

Server -> Database ++: Sync query
    Database --> Server: Cached
return

@enduml
